# Local dev only: copy to .env and fill in. NEVER commit the real .env.
# In production this file is rendered on the server by .github/workflows/deploy.yml
# from GitHub Secrets/Variables — do not hand-edit it there.

NODE_ENV=production
PORT=8080

# Browser origins allowed to POST the form (comma-separated, no trailing slash).
ALLOWED_ORIGINS=https://daeppen.dev,https://www.daeppen.dev

# Reverse-proxy hops to trust for the real client IP (compose nginx/traefik = 1).
TRUST_PROXY=1

# --- Spam thresholds ---
RATE_WINDOW_MS=900000   # 15 min
RATE_MAX=5              # submissions per window per IP
MIN_FILL_MS=2500        # reject forms submitted faster than this
MAX_FORM_AGE_MS=3600000 # reject form tokens older than this (1h)

# --- SMTP delivery ---
# Leave SMTP_HOST empty to run in dev/log mode (messages printed, not emailed).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false        # true only for port 465
SMTP_USER=apikey-or-user
SMTP_PASS=changeme
MAIL_FROM="Portfolio <maurice@daeppen.dev>"
MAIL_TO=maurice@daeppen.dev

# --- Privacy / storage ---
# Salt used to pseudonymize IPs before storing. Set a long random string.
IP_SALT=replace-with-a-long-random-string
# Secret used to sign form tokens (anti-spam/replay). Long random string.
# Falls back to IP_SALT if unset, but set its own value in production.
FORM_TOKEN_SECRET=replace-with-another-long-random-string
# Append-only backup of accepted messages. Empty string disables it.
STORE_FILE=/data/messages.jsonl
# Delete backup records older than this many days (DSGVO). 0 = keep forever.
RETENTION_DAYS=180
